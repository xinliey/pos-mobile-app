<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DryLatexApp.MainPage">

    <ScrollView>
        <VerticalStackLayout Spacing="20">

            <Label 
                Text="บิลขี้ยาง"
                FontSize="30"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Margin="0,30"
                />
            
            
            <!-- Name -->
            <HorizontalStackLayout Spacing="85">
                <Label
                Text="ชื่อ"
                FontSize="25"
                />
            <Entry 
            x:Name="NameInput"
            Placeholder="Enter Name"
                FontSize="20"
            WidthRequest="600"
                
                />
</HorizontalStackLayout>
            
            <!-- weight -->
            <HorizontalStackLayout Spacing="45">
                <Label
    Text="น้ำหนัก"
    FontSize="25"
                Margin="0,10"/>
                <Entry 
x:Name="WeightInput"
Placeholder="Enter weight"
                    FontSize="25"
                    WidthRequest="600"
                Keyboard="Numeric"/>
            </HorizontalStackLayout>

            <!-- bucket -->
            <HorizontalStackLayout Spacing="20">
               <Label
    Text="หักถัง/เข่ง"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="BucketInput"
Placeholder="Enter weight" 
                FontSize="25"
                WidthRequest="600"
                Keyboard="Numeric"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout  Spacing="85">
               <!-- deduct-->
            <Label
    Text="หัก"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="DeductInput"
                
Placeholder="Enter weight" 
                FontSize="25"
                WidthRequest="600"
                Keyboard="Numeric"/> 
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="67">
                <Label
    Text="ราคา"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="PriceInput"
Placeholder="Enter Price" 
                FontSize="25"
                WidthRequest="600"
                Keyboard="Numeric"/>
            </HorizontalStackLayout>
     

            <!-- save -->
            <Button
                x:Name="CounterBtn"
                Text="ปริ้น"
                FontSize="20"    
                 Margin="0,40"
                Clicked="OnCounterClicked" />

            <Button
    x:Name="EditBtn"
    Text="แก้ไข"
                FontSize="20"
                Margin="0,10"
                Clicked="EditBtn_Clicked"
            />
            <!-- summarize -->
            <Button
      x:Name="SumBtn"
      Text="สรุปยอดวันนี้"
      FontSize="20"    
      Clicked="SumBtn_Clicked"
      />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
