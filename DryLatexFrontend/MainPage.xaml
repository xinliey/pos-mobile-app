<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DryLatexApp.MainPage">

    <ScrollView>
        <VerticalStackLayout Spacing="20">
            <!-- Component Selection -->
          
            <Label 
                Text="บิลขี้ยาง"
                FontSize="30"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Margin="0,30"
                />
            <HorizontalStackLayout Spacing="20" VerticalOptions="Center">

                <Label 
        Text="รูปแบบยาง"
        FontSize="25"
        VerticalOptions="Center"/>

                <Picker 
        x:Name="LatexType"
        Title=""
        FontSize="25"
                    WidthRequest="600">
                    <Picker.Items>
                        <x:String>ขี้ยาง</x:String>
                        <x:String>ยางแผ่น</x:String>
                    </Picker.Items>
                </Picker>

            </HorizontalStackLayout>

            <!-- Name -->
            <HorizontalStackLayout Spacing="85">
                <Label
                Text="ชื่อ"
                FontSize="25"
                />
            <Entry 
            x:Name="NameInput"
            Placeholder="Enter Name"
                FontSize="20"
            WidthRequest="600"
                
                />
</HorizontalStackLayout>
            
            <!-- weight -->
            <HorizontalStackLayout Spacing="45">
                <Label
    Text="น้ำหนัก"
    FontSize="25"
                Margin="0,10"/>
                <Entry 
x:Name="WeightInput"
Placeholder="Enter weight"
                    FontSize="25"
                    WidthRequest="600"
                Keyboard="Numeric"/>
            </HorizontalStackLayout>

            <!-- bucket -->
            <HorizontalStackLayout Spacing="20">
               <Label
    Text="หักถัง/เข่ง"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="BucketInput"
Placeholder="Enter weight" 
                FontSize="25"
                WidthRequest="600"
                Keyboard="Numeric"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout  Spacing="85">
               <!-- deduct-->
            <Label
    Text="หัก"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="DeductInput"
                
Placeholder="Enter weight" 
                FontSize="25"
                WidthRequest="600"
                Keyboard="Numeric"/> 
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="67">
                <Label
    Text="ราคา"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="PriceInput"
Placeholder="Enter Price" 
                FontSize="25"
                WidthRequest="600"
                Keyboard="Numeric"/>
            </HorizontalStackLayout>
            <!-- Component Selection -->
            <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                <Label 
 Text="รูปแบบยาง"
 FontSize="25"
 VerticalOptions="Center"/>
            <Picker 
            x:Name="Dividened"
            Title=""
                FontSize="25"
                WidthRequest="600"
               >
                <Picker.Items>
                    <x:String>ไม่แบ่ง</x:String>
                    <x:String>6/4</x:String>
                    <x:String>5/5</x:String>
                </Picker.Items>
            </Picker>
                </HorizontalStackLayout>

            <!-- save -->
            <Button
                x:Name="CounterBtn"
                Text="ปริ้น"
                FontSize="20"    
                 Margin="0,40"
                Clicked="OnCounterClicked" />

      
            <!-- summarize -->
          

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
