<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DryLatexApp.MainPage">

    <ScrollView>
        <VerticalStackLayout>
            
            <Label 
                Text="บิลขี้ยาง"
                FontSize="30"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Margin="0,30"
                />
            
            <!-- Name -->
            <Label
                Text="ชื่อ"
                FontSize="25"
                />
            <Entry 
            x:Name="NameInput"
            Placeholder="Enter Name"
                />

            <!-- weight -->
            <Label
    Text="น้ำหนัก"
    FontSize="25"
                Margin="0,10"/>
            <Entry 
x:Name="WeightInput"
Placeholder="Enter weight"
                Keyboard="Numeric"/>
            <!-- bucket -->
            <Label
    Text="หักถัง/เข่ง"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="BucketInput"
Placeholder="Enter weight" 
                Keyboard="Numeric"/>
            <!-- deduct-->
            <Label
    Text="หัก"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="DeductInput"
                
Placeholder="Enter weight" 
                Keyboard="Numeric"/>

            <Label
    Text="ราคา"
    FontSize="25"
                 Margin="0,10"/>
            <Entry 
x:Name="PriceInput"
Placeholder="Enter Price" 
                Keyboard="Numeric"/>

            <!-- save -->
            <Button
                x:Name="CounterBtn"
                Text="ปริ้น"
                FontSize="20"    
                 Margin="0,40"
                Clicked="OnCounterClicked" />
            <!-- summarize -->
            <Button
      x:Name="SumBtn"
      Text="สรุปยอดวันนี้"
      FontSize="20"    
      Clicked="SumBtn_Clicked"
      />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
